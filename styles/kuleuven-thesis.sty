%%
%% KU Leuven Master Thesis Style
%% Based on the official KU Leuven style guide for master theses
%% Faculty of Science – Geography & Tourism
%%
\ProvidesPackage{styles/kuleuven-thesis}[2026/03/06 KU Leuven Master Thesis Style]

% =============================================================================
% Required packages
% =============================================================================
\RequirePackage[T1]{fontenc}
\RequirePackage{geometry}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{titlesec}
\RequirePackage{fancyhdr}
\RequirePackage{setspace}
\RequirePackage{etoolbox}
\RequirePackage{ifthen}
\RequirePackage{helvet}  % Helvetica (closest to Helvetica Neue in standard LaTeX)

% =============================================================================
% KU Leuven colors (official corporate identity)
% =============================================================================
\definecolor{kulblue}{RGB}{29,141,176}    % KU Leuven blue (Science group)
\definecolor{kulblack}{RGB}{0,0,0}
\definecolor{kulgray}{RGB}{128,128,128}
\definecolor{kullightgray}{RGB}{200,200,200}
\definecolor{kulolivegrey}{RGB}{130,135,90} % Olive-grey for KUL faculty text
\definecolor{kulnavyblue}{RGB}{0,47,95}     % Dark navy for VUB faculty text

% =============================================================================
% Font: Helvetica / Arial family (KU Leuven house style)
% =============================================================================
\renewcommand{\familydefault}{\sfdefault}

% =============================================================================
% Page geometry
% =============================================================================
\geometry{
    a4paper,
    left=25mm,
    right=25mm,
    top=25mm,
    bottom=25mm,
    includefoot
}

% =============================================================================
% Commands for thesis metadata
% =============================================================================
\newcommand\@thesistitle{Thesis Title}
\newcommand\@thesissubtitle{}
\newcommand\@thesisauthor{Author Name}
\newcommand\@thesispromotor{}
\newcommand\@thesispromotoraffil{}
\newcommand\@thesiscopromotor{}
\newcommand\@thesiscopromotoraf{}
\newcommand\@thesismentor{}
\newcommand\@thesismentoraffil{}
\newcommand\@thesisassessor{}
\newcommand\@academicyear{20XX--20XX}
\newcommand\@thesisfacultykul{Faculty of Science}
\newcommand\@thesisfacultyvub{Faculty of Science and Bio-Engineering Sciences}
\newcommand\@thesisdepartment{Department of Earth and Environmental Sciences}
\newcommand\@thesisdegree{Master of Science in Geography}
\newcommand\@thesisreader{}
\newcommand\@thesiscoverimage{}

\newcommand{\thesistitle}[1]{\renewcommand\@thesistitle{#1}}
\newcommand{\thesissubtitle}[1]{\renewcommand\@thesissubtitle{#1}}
\newcommand{\thesisauthor}[1]{\renewcommand\@thesisauthor{#1}}
\newcommand{\thesispromotor}[2][]{\renewcommand\@thesispromotor{#2}\renewcommand\@thesispromotoraffil{#1}}
\newcommand{\thesiscopromotor}[2][]{\renewcommand\@thesiscopromotor{#2}\renewcommand\@thesiscopromotoraf{#1}}
\newcommand{\thesismentor}[2][]{\renewcommand\@thesismentor{#2}\renewcommand\@thesismentoraffil{#1}}
\newcommand{\thesisassessor}[1]{\renewcommand\@thesisassessor{#1}}
\newcommand{\thesisreader}[1]{\renewcommand\@thesisreader{#1}}
\newcommand{\academicyear}[1]{\renewcommand\@academicyear{#1}}
\newcommand{\thesisfacultykul}[1]{\renewcommand\@thesisfacultykul{#1}}
\newcommand{\thesisfacultyvub}[1]{\renewcommand\@thesisfacultyvub{#1}}
% Legacy: \thesisfaculty sets VUB faculty for backwards compatibility
\newcommand{\thesisfaculty}[1]{\renewcommand\@thesisfacultyvub{#1}}
\newcommand{\thesisdepartment}[1]{\renewcommand\@thesisdepartment{#1}}
\newcommand{\thesisdegree}[1]{\renewcommand\@thesisdegree{#1}}
\newcommand{\thesiscoverimage}[1]{\renewcommand\@thesiscoverimage{#1}}

% =============================================================================
% Title page (matching official VUB/KU Leuven Geography front page template)
% =============================================================================
\renewcommand{\maketitle}{%
\begin{titlepage}
    \newgeometry{left=20mm, right=20mm, top=12mm, bottom=10mm}
    \thispagestyle{empty}
    \sffamily

    % --- Row 1: KU Leuven logo + KUL Faculty (right) + Green Bar ---
    \noindent
    % --- Green Header Bar ---
    \begin{tikzpicture}[remember picture,overlay]
        \node[anchor=north,inner sep=0pt] at ([yshift=-20mm]current page.north) {\includegraphics{styles/Style_assets/green_header.pdf}};
    \end{tikzpicture}%
    % --- Ku Leuven Logo ---
    \begin{minipage}[c]{0.40\textwidth}
        \vspace{0pt}%
        \includegraphics[height=20mm]{styles/Style_assets/kuleuven_logo.pdf}%
    \end{minipage}%
    \hfill
    % --- Kul Faculty text ---
    \begin{minipage}[c]{0.55\textwidth}
        \vspace*{18mm}%
        \raggedleft
        {\fontsize{11}{13}\selectfont\textcolor{white}{\MakeUppercase{\@thesisfacultykul}}\par}
    \end{minipage}

    \vspace{15mm}

    % --- Row 2: VUB logo + VUB Faculty text ---
    \noindent
    \begin{minipage}[c]{0.40\textwidth}
        \vspace{0pt}%
        \includegraphics[height=21mm]{styles/Style_assets/vub_logo_cmyk.pdf}%
    \end{minipage}%
    % --- VUB Faculty text  ---
    \hfill
    \begin{minipage}[c]{0.50\textwidth}
        \raggedleft
        {\fontsize{11}{13}\selectfont\textcolor{black}{\MakeUppercase{\@thesisfacultyvub}}\par}
    \end{minipage}

    \vspace{25mm}

    % --- Title (large, blue, left-aligned) ---
    {\fontsize{36}{42}\selectfont\textcolor{kulblue}{\@thesistitle}\par}%

    \ifx\@thesissubtitle\empty\else
        \vspace{2mm}
        {\fontsize{18}{22}\selectfont\textit{\@thesissubtitle}\par}%
    \fi

    % --- Optional cover image (centered, max 10cm height) ---
    \expandafter\ifx\expandafter\relax\@thesiscoverimage\relax\else
        \vspace{8mm}
        \begin{center}
            \includegraphics[height=10cm,width=\textwidth,keepaspectratio]{\@thesiscoverimage}
        \end{center}
    \fi

    \vfill

    % --- Author name (bold, right-aligned) ---
    \begin{flushright}
        {\fontsize{14}{17}\selectfont\textbf{\@thesisauthor}\par}
    \end{flushright}

    \vspace{20mm}

    % --- Bottom section: supervisors left, degree right ---
    \noindent
    \begin{minipage}[t]{0.48\textwidth}
        \fontsize{11}{14}\selectfont
        \ifx\@thesispromotor\empty\else
            Supervisor: \@thesispromotor\\*
            \ifx\@thesispromotoraffil\empty\else
                {\textcolor{kulblue}{\textit{\@thesispromotoraffil}}}\\[2mm]
            \fi
        \fi
        \ifx\@thesiscopromotor\empty\else
            Co-supervisor: \@thesiscopromotor\\*
            \ifx\@thesiscopromotoraf\empty\else
                {\textcolor{kulblue}{\textit{\@thesiscopromotoraf}}}\\[2mm]
            \fi
        \fi
        \ifx\@thesismentor\empty\else
            Mentor: \@thesismentor\\*
            \ifx\@thesismentoraffil\empty\else
                {\textcolor{kulblue}{\textit{\@thesismentoraffil}}}\\[2mm]
            \fi
        \fi
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.48\textwidth}
        \raggedleft
        \fontsize{11}{14}\selectfont
        Thesis presented in\\
        fulfillment of the requirements\\
        for the degree of \@thesisdegree\par
    \end{minipage}

    \vspace{12mm}

    % --- Academic year (right-aligned, near bottom) ---
    \begin{flushright}
        {\fontsize{11}{14}\selectfont Academic year \@academicyear\par}
    \end{flushright}

    \restoregeometry
\end{titlepage}
}

