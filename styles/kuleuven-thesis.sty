% =============================================================================
% Page styles and headers/footers
% =============================================================================
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}
\setlength{\footskip}{15mm}

\fancypagestyle{plain}{%
    \fancyhf{}
    \renewcommand{\headrulewidth}{0pt}
    \fancyfoot[C]{\thepage}
}

% =============================================================================
% Paragraph formatting
% =============================================================================
\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}
\onehalfspacing

% =============================================================================
% Chapter and section formatting
% =============================================================================
\titleformat{\section}
    {\Large\bfseries\color{kulblue}}
    {\thesection}{1em}{}
\titleformat{\subsection}
    {\large\bfseries}
    {\thesubsection}{1em}{}
\titleformat{\subsubsection}
    {\normalsize\bfseries}
    {\thesubsubsection}{1em}{}

% =============================================================================
% Front matter / main matter commands for page numbering
% Roman numerals for pages before chapter 1, Arabic from chapter 1 onwards
% =============================================================================
\newcommand{\frontmatter}{%
    \cleardoublepage
    \pagenumbering{roman}
}

\newcommand{\mainmatter}{%
    \cleardoublepage
    \pagenumbering{arabic}
}

\newcommand{\backmatter}{%
    \cleardoublepage
}

% =============================================================================
% Preface / Foreword environment
% =============================================================================
\newenvironment{preface}{%
    \section*{Preface}
    \addcontentsline{toc}{section}{Preface}
}{}

\newenvironment{voorwoord}{%
    \section*{Voorwoord}
    \addcontentsline{toc}{section}{Voorwoord}
}{}

% =============================================================================
% Contribution statement environment
% =============================================================================
\newenvironment{contributionstatement}{%
    \section*{Contribution Statement}
    \addcontentsline{toc}{section}{Contribution Statement}
}{}

% =============================================================================
% Abstract environments (NL + EN)
% =============================================================================
\newenvironment{abstractEN}{%
    \section*{Abstract}
    \addcontentsline{toc}{section}{Abstract}
}{}

\newenvironment{abstractNL}{%
    \section*{Samenvatting}
    \addcontentsline{toc}{section}{Samenvatting}
}{}

% =============================================================================
% List of abbreviations / symbols
% =============================================================================
\newenvironment{abbreviations}{%
    \section*{List of Abbreviations}
    \addcontentsline{toc}{section}{List of Abbreviations}
}{}

\newenvironment{listofsymbols}{%
    \section*{List of Symbols}
    \addcontentsline{toc}{section}{List of Symbols}
}{}

\endinput
